# Admin panel
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SESSION_SECRET=random-secret-for-session-tokens
# אימייל(ים) של בעל החנות — גישה ל-/admin עם Google
ADMIN_EMAILS=owner@gmail.com

# Google OAuth (Auth.js) — כניסת לקוחות ומנהל
AUTH_SECRET=random-secret-for-auth-js
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Email (Resend) — שליחת הזמנות לחנות וללקוח
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=orders@tzipypuff.co.il

# Site URL for sitemap/SEO
NEXT_PUBLIC_SITE_URL=https://tzipypuff.co.il

# Database (Neon Postgres) — when set, replaces JSON file storage
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Stripe — תשלום בכרטיס אשראי (אופציונלי)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
