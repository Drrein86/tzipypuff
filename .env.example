# Admin panel
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SESSION_SECRET=random-secret-for-session-tokens
# אימייל(ים) של בעל החנות — גישה ל-/admin עם Google
ADMIN_EMAILS=elior2280@gmail.com

# Google OAuth (Auth.js) — כניסת לקוחות ומנהל
AUTH_SECRET=random-secret-for-auth-js
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Email (Resend) — שליחת הזמנות לחנות וללקוח
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=orders@tzipypuff.co.il

# Site URL for sitemap/SEO
NEXT_PUBLIC_SITE_URL=https://tzipypuff.co.il

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
# Service role — server only, never commit real value
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# Supabase Postgres — בחר אחת מהאפשרויות:

# אפשרות A (הכי פשוט): העתק URI מ-Supabase → Settings → Database → Connect → Session pooler
# DATABASE_URL=postgresql://postgres.redxzyfjrgfgzjomgzdj:...@aws-0-....pooler.supabase.com:5432/postgres

# אפשרות B: סיסמה גולמית במרכאות (לא %40/%23 — הקוד מקודד לבד)
SUPABASE_DB_PASSWORD="your-db-password-here"

# Stripe — תשלום בכרטיס אשראי (אופציונלי)
